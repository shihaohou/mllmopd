# Copy this file to `.env` and fill in. `.env` is gitignored.
# Both Mac and the H800 dev box read these; values differ — see comments.
#
# Mac usage: this file isn't really needed; local analysis only reads from
# runs/ via the rsync'd JSONL outputs. But keeping a Mac .env makes some
# diagnostic scripts importable.

# --- Paths (absolute) ---
# Mac:    /Users/houshihao/project/code/mllmopd
# Devbox: e.g. /home/web_server/antispam/project/houshihao/mllmopd
export MLLMOPD_ROOT="$(pwd)"

# Uni-OPD's docs assume BASE_DIR holds Uni-OPD/, Megatron-LM/, sglang/ as siblings.
# In our layout these are submodules under third_party/, so BASE_DIR == third_party/.
export BASE_DIR="${MLLMOPD_ROOT}/third_party"

# Conda root (where `conda` lives). Devbox example: /opt/miniconda3 or ~/miniconda3
export CONDA_PATH="${HOME}/miniconda3"

# Pinned upstream commits — DO NOT change without coordinating env rebuild.
export SGLANG_COMMIT="24c91001cf99ba642be791e099d358f4dfe955f5"
export MEGATRON_COMMIT="3714d81d418c9f1bca4594fc35f9e8289f652862"

export MILES_DIR="${BASE_DIR}/Uni-OPD/miles"
export MEGATRON_DIR="${BASE_DIR}/Megatron-LM"
export SGLANG_DIR="${BASE_DIR}/sglang"
export LMMS_EVAL_PATH="${BASE_DIR}/lmms-eval"
export G_OPD_PATH="${BASE_DIR}/G-OPD"

# --- HF / data caches ---------------------------------------------------------
# On Mac: leave default.
# On devbox: put on the same disk as the dataset cache to avoid duplication.
export HF_HOME="${HF_HOME:-${HOME}/.cache/huggingface}"
export HF_HUB_ENABLE_HF_TRANSFER=1
export HF_TOKEN=""   # only if you need gated models

# --- Server data/model inventory (devbox-specific) ----------------------------
# These point at directories that already exist on arc-wlf1-ge103-4. They are
# overridable so the same configs/scripts work on any other box.
# Leave empty on Mac.
export MLLMOPD_MODELS_ROOT="${MLLMOPD_MODELS_ROOT:-/home/web_server/antispam/project/houshihao/models}"
export MLLMOPD_DATASETS_ROOT="${MLLMOPD_DATASETS_ROOT:-/home/web_server/antispam/project/houshihao/datasets}"

# Specific assets (resolved at script time; only present on devbox)
export MMR1_3B_SFT_CKPT="${MLLMOPD_DATASETS_ROOT}/MMR1-3B-SFT"
export MMR1_7B_RL_CKPT="${MLLMOPD_DATASETS_ROOT}/MMR1-7B-RL"
export MMR1_7B_SFT_CKPT="${MLLMOPD_DATASETS_ROOT}/MMR1-7B-SFT"      # ← MISSING; needed for H3
export MMR1_RL_DATA="${MLLMOPD_DATASETS_ROOT}/MMR1-RL"
export VIRL39K_PATH="${MLLMOPD_DATASETS_ROOT}/ViRL39K"

# Eval benchmarks (only the ones we have)
export MATHVISTA_PATH="${MLLMOPD_DATASETS_ROOT}/MathVista-mini"
export POPE_PATH="${MLLMOPD_DATASETS_ROOT}/POPE-adversarial"
# MathVision / MathVerse / LogicVista / ChartQA / HallusionBench / CharXiv / MMMU
# all need to be downloaded — see docs/server-inventory.md.

# --- Run outputs --------------------------------------------------------------
# On devbox, put these on fast local disk (NOT the slow NAS if you have a choice).
export MLLMOPD_RUNS="${MLLMOPD_RUNS:-${HOME}/mllmopd_runs}"
export MLLMOPD_DATA="${MLLMOPD_DATA:-${HOME}/mllmopd_data}"

# --- WandB (optional) ---------------------------------------------------------
export WANDB_API_KEY=""
export WANDB_PROJECT="mllmopd"
export WANDB_ENTITY=""

# --- Distributed (single-node 8-GPU devbox) -----------------------------------
export CUDA_VISIBLE_DEVICES="0,1,2,3,4,5,6,7"
export NCCL_DEBUG="WARN"
export TORCH_CUDA_ARCH_LIST="9.0"
