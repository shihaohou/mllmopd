# --- Local env / secrets ---
.env
.env.local
*.local

# --- Third-party submodules ---
# Submodules listed in .gitmodules are tracked by gitlink, not by gitignore.
# This block ignores ad-hoc clones / downloads under third_party/ while
# explicitly re-including the four upstream paths we register as submodules.
/third_party/*
!/third_party/.gitkeep
!/third_party/Uni-OPD
!/third_party/Megatron-LM
!/third_party/sglang
!/third_party/lmms-eval
!/third_party/G-OPD

# --- Big artifacts (live on dev box / scratch, symlinked in) ---
# Leading slash = only at repo root. Without it, gitignore would also match
# scripts/data/, src/mllmopd/data/, etc.
/runs/*
!/runs/audit/
/runs/audit/*
!/runs/audit/smoke500/
!/runs/audit/level1_smoke/
!/runs/audit/level1_v2_4k/
!/runs/audit/level1_v3_sysprompt/
!/runs/audit/level1_v4_sysprompt_fixed/
/data/
/models/
wandb/
outputs/
checkpoints/
*.ckpt
*.safetensors
*.bin
*.pt

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
.venv/
venv/
.python-version

# --- Notebooks ---
.ipynb_checkpoints/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# --- Logs ---
*.log
!/runs/audit/smoke500/*.log
!/runs/audit/level1_smoke/*.log
!/runs/audit/level1_v2_4k/*.log
!/runs/audit/level1_v3_sysprompt/*.log
!/runs/audit/level1_v4_sysprompt_fixed/*.log
logs/
